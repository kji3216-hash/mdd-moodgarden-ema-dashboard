{
  "project_overview": {
    "title": "주요 우울장애(MDD) 유전-뇌-행동 삼각구조 시각화",
    "description": "MDD의 유전적 취약성, 뇌 네트워크 이상, 행동/증상을 삼각 피드백 구조로 매핑한 지식 구조",
    "created_date": "2026-06-12",
    "theoretical_framework": "Yuan et al. (2026) Neuron - Pathological Attractor Model; Menon (2011) Triple Network Model",
    "data_source": "PGC 2025 Cell, Zhang 2026 Psychol Med ALE, Zhao 2024 Psychol Med, literature_validation_report.md"
  },
  "symptom_clusters": {
    "emotional": {
      "symptoms": ["depressed_mood", "emptiness", "irritability", "crying"],
      "description": "정서 증상: 지속적 우울감, 공허감, 짜증",
      "circuits": ["dmn_overactivity", "sgacc_hyperactivity", "amygdala_hypersensitivity"],
      "key_mechanisms": ["dmn_rumination_loop", "negative_emotional_amplification", "self_referential_negativity"],
      "measurement": "PHQ-9, HAMD-17, MADRS"
    },
    "anhedonia": {
      "symptoms": ["loss_of_interest", "reduced_pleasure", "social_withdrawal"],
      "description": "무쾌감: 이전에 즐겼던 활동에서의 흥미/즐거움 상실",
      "circuits": ["reward_circuit_dysfunction"],
      "key_mechanisms": ["reward_anticipation_deficit", "aberrant_striatal_processing", "motivation_loss"],
      "measurement": "SHAPS, TEPS, Experience Sampling"
    },
    "cognitive": {
      "symptoms": ["concentration_deficit", "indecision", "brain_fog", "memory_complaints"],
      "description": "인지 증상: 집중력 저하, 우유부단, 뇌 안개",
      "circuits": ["pfc_dysregulation", "hippocampus_atrophy", "salience_network_dysfunction"],
      "key_mechanisms": ["compensatory_hyperactivation", "executive_dysfunction", "context_processing_deficit"],
      "measurement": "Digit Span, TMT, Stroop Test"
    },
    "rumination": {
      "symptoms": ["repetitive_negative_thoughts", "brooding", "self_criticism"],
      "description": "반추: 반복적 부정적 사고, 자기비하적 반성",
      "circuits": ["dmn_overactivity", "pfc_dysregulation"],
      "key_mechanisms": ["dmn_dlpfc_imbalance", "sn_switching_failure", "self_referential_loop"],
      "measurement": "RRS (Ruminative Response Scale)"
    },
    "somatic": {
      "symptoms": ["sleep_disturbance", "appetite_change", "fatigue", "psychomotor_change"],
      "description": "생체/신체 증상: 수면장애, 식욕변화, 피로, 정신운동 변화",
      "circuits": ["hpa_axis_dysregulation"],
      "key_mechanisms": ["cortisol_dysregulation", "inflammation_elevation", "circadian_disruption"],
      "measurement": "PSQI, Actigraphy, BMI tracking"
    },
    "social": {
      "symptoms": ["social_withdrawal", "interpersonal_difficulty", "negative_bias"],
      "description": "사회적 증상: 사회적 위축, 대인관계 어려움, 타인 의도 부정적 해석",
      "circuits": ["dmn_overactivity", "amygdala_hypersensitivity"],
      "key_mechanisms": ["mentalizing_deficit", "threat_hyperdetection", "social_reward_blunting"],
      "measurement": "WHODAS, SAS-SR"
    }
  },
  "genetic_factors": {
    "BDNF_Val66Met": {
      "gene": "BDNF (Brain-Derived Neurotrophic Factor)",
      "variant": "Val66Met (rs6265)",
      "risk_allele": "Met",
      "mechanism": "BDNF 분비 20-30% 감소 → 신경가소성 저하 → 해마 신경발생 감소",
      "evidence_level": "strong",
      "effect_on_circuits": {
        "hippocampus_atrophy": {"weight": 0.40, "direction": "increase", "evidence": "2024 AIMS Neuroscience meta-analysis"},
        "pfc_dysregulation": {"weight": 0.25, "direction": "increase", "evidence": "2023 Neuroscience & Biobehavioral Reviews"}
      },
      "behavioral_effects": ["memory_impairment", "treatment_resistance", "cognitive_symptoms"],
      "key_references": ["Egan et al. 2003 Cell", "Verhagen et al. 2010 Mol Psychiatry meta-analysis"]
    },
    "FKBP5_rs1360780": {
      "gene": "FKBP5 (FK506 Binding Protein 5)",
      "variant": "rs1360780",
      "risk_allele": "T",
      "mechanism": "GR 감수성 저하 → 코르티솔 음성피드백 약화 → HPA 축 과활성",
      "evidence_level": "strong",
      "gxe_interaction": "아동기 외상 × T allele → MDD 위험 3-5배 증가",
      "effect_on_circuits": {
        "hpa_axis_dysregulation": {"weight": 0.50, "direction": "increase", "evidence": "2023 Frontiers Psychiatry"},
        "hippocampus_atrophy": {"weight": 0.35, "direction": "increase", "evidence": "cortisol neurotoxicity pathway"},
        "amygdala_hypersensitivity": {"weight": 0.30, "direction": "increase", "evidence": "hyperarousal maintenance"}
      },
      "behavioral_effects": ["stress_sensitivity", "sleep_disturbance", "chronification_tendency"],
      "key_references": ["Binder 2009 Mol Psychiatry", "Klengel et al. 2013 Nature Neuroscience"]
    },
    "HTTLPR_SLC6A4": {
      "gene": "SLC6A4 (Serotonin Transporter)",
      "variant": "5-HTTLPR promoter polymorphism",
      "risk_allele": "S (short)",
      "mechanism": "세로토닌 재흡수 운반체 발현 감소 → 편도체 과민",
      "evidence_level": "controversial",
      "controversy_note": "G×E 상호작용은 대규모 메타분석(Border 2019, Am J Psychiatry)에서 재현 실패. 2025 MDPI 메타분석에서 재확인. 유전-뇌(amygdala FC) 효과는 비교적 견고.",
      "effect_on_circuits": {
        "amygdala_hypersensitivity": {"weight": 0.30, "direction": "increase", "evidence": "multiple fMRI studies"},
        "pfc_dysregulation": {"weight": 0.15, "direction": "increase", "evidence": "vmPFC-amygdala connectivity"}
      },
      "behavioral_effects": ["negative_emotional_bias", "stress_vulnerability"],
      "key_references": ["Caspi et al. 2003 Science", "Border et al. 2019 Am J Psychiatry", "2025 MDPI IJMS meta-analysis"]
    },
    "NR3C1": {
      "gene": "NR3C1 (Glucocorticoid Receptor Gene)",
      "variant": "multiple SNPs (e.g., rs6198, BclI)",
      "risk_allele": "variant-dependent",
      "mechanism": "GR 기능 저하 → 코르티솔 음성피드백 약화 → HPA 축 항진",
      "evidence_level": "moderate",
      "gxe_interaction": "아동기 학대 × NR3C1 변이 → GR 감수성 변화",
      "effect_on_circuits": {
        "hpa_axis_dysregulation": {"weight": 0.35, "direction": "increase", "evidence": "2020 Acta Neuropsychiatrica systematic review"}
      },
      "behavioral_effects": ["stress_dysregulation", "early_life_stress_sensitivity"],
      "key_references": ["2020 Acta Neuropsychiatrica systematic review"]
    },
    "PRS": {
      "gene": "Polygenic Risk Score (genome-wide)",
      "variant": "697 independent associations at 636 loci (PGC 2025)",
      "mechanism": "다유전자 누적 위험 → 전반적 신경발달/기능 조절",
      "evidence_level": "strong",
      "effect_on_circuits": {
        "dmn_overactivity": {"weight": 0.20, "direction": "increase", "evidence": "2025 PMC PRS-sgACC FC study"},
        "sgacc_hyperactivity": {"weight": 0.20, "direction": "increase", "evidence": "2025 PMC PRS-sgACC FC study"},
        "reward_circuit_dysfunction": {"weight": 0.15, "direction": "increase", "evidence": "2025 Mol Psychiatry systematic review"}
      },
      "behavioral_effects": ["general_vulnerability", "earlier_onset", "treatment_resistance"],
      "key_references": ["PGC MDD 2025 Cell (685,808 cases × 4,364,225 controls)"]
    }
  },
